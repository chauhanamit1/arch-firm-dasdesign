# Environment Variables Template
# Copy this file to .env and fill in your values

# Database Configuration (Production)
DB_PASSWORD=your_secure_database_password_here

# Strapi Secrets (Generate secure random strings)
# You can generate these using: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
ADMIN_JWT_SECRET=your_admin_jwt_secret_here
APP_KEYS=your_app_keys_here
API_TOKEN_SALT=your_api_token_salt_here

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:1337

# SonarQube Configuration (Optional)
SONAR_TOKEN=your_sonarqube_token_here
SONAR_HOST_URL=http://localhost:9000

# Production Domain (for HTTPS)
DOMAIN=your-domain.com

# Email Configuration (Optional - for Strapi email plugin)
EMAIL_PROVIDER=sendgrid
EMAIL_PROVIDER_API_KEY=your_sendgrid_api_key_here
EMAIL_DEFAULT_FROM=noreply@your-domain.com
EMAIL_DEFAULT_REPLY_TO=support@your-domain.com

# AWS S3 Configuration (Optional - for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_BUCKET=your-bucket-name

# Node Environment
NODE_ENV=development